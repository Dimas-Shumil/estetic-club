generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  OWNER
  STAFF
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model AdminUser {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(STAFF)
  isActive     Boolean   @default(true)

  lastLoginAt DateTime?

  sessions      AdminSession[]
  assignedLeads Lead[]
  auditLogs     AdminAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([isActive])
}

model AdminSession {
  id Int @id @default(autoincrement())

  tokenHash     String @unique
  csrfTokenHash String @unique

  userId Int
  user   AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt  DateTime
  lastUsedAt DateTime @default(now())

  ipAddress String @default("")
  userAgent String @default("")

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Lead {
  id Int @id @default(autoincrement())

  name    String
  phone   String
  service String @default("")
  message String @default("")

  status          LeadStatus @default(NEW)
  internalComment String     @default("")

  source String @default("website")

  consentAccepted   Boolean   @default(false)
  consentAcceptedAt DateTime?

  assignedToId Int?
  assignedTo   AdminUser? @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([assignedToId])
  @@index([createdAt])
}

model BlogPost {
  id Int @id @default(autoincrement())

  authorName String?
  authorRole String?
  expertNote String?

  coverAlt String?

  focusKeyword   String?
  seoTitle       String?
  seoDescription String?

  slug    String @unique
  title   String
  excerpt String
  content String @default("")

  category     String @default("Журнал")
  categorySlug String @default("hair-care")

  coverImage  String @default("/site/img/blog/blog-hero.png")
  readingTime String @default("3 мин")

  isPublished Boolean   @default(false)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished])
  @@index([categorySlug])
  @@index([publishedAt])
}

model Work {
  id Int @id @default(autoincrement())

  slug String @unique

  title   String
  excerpt String @default("")

  category     String @default("Работа")
  categorySlug String @default("airtouch")

  beforeImage String
  afterImage  String

  technique String @default("")
  duration  String @default("")

  heroImage       String @default("")
  experienceImage String @default("")
  heroQuote       String @default("")
  story           String @default("")

  // Временно оставляем для совместимости с текущим публичным JS.
  // После перевода галереи на WorkImage это поле удалим отдельной миграцией.
  gallery String @default("[]")

  images WorkImage[]

  isPublished Boolean @default(false)
  showOnHome  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished])
  @@index([showOnHome])
  @@index([categorySlug])
}

model WorkImage {
  id Int @id @default(autoincrement())

  workId Int
  work   Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  imagePath String
  alt       String @default("")
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
  @@index([workId, sortOrder])
}

model AdminAuditLog {
  id Int @id @default(autoincrement())

  userId Int?
  user   AdminUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  action     String
  entityType String
  entityId   String @default("")

  // Сюда будем класть безопасный JSON без паролей,
  // cookie, session token и других секретов.
  details String @default("{}")

  ipAddress String @default("")
  userAgent String @default("")

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

enum OrderStatus {
  NEW
  CONFIRMED
  ASSEMBLING
  READY
  COMPLETED
  CANCELLED
}

enum FulfillmentMethod {
  PICKUP
  DELIVERY
}

model ProductCategory {
  id Int @id @default(autoincrement())

  name        String
  slug        String @unique
  description String @default("")
  imagePath   String @default("")

  parentId Int?
  parent   ProductCategory?  @relation("ProductCategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children ProductCategory[] @relation("ProductCategoryTree")

  products     Product[]
  filterGroups FilterGroup[]

  sortOrder   Int     @default(100)
  isPublished Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([isPublished, sortOrder])
}

model Brand {
  id Int @id @default(autoincrement())

  name      String
  slug      String @unique
  logoPath  String @default("")
  sortOrder Int    @default(100)

  isPublished Boolean @default(true)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished, sortOrder])
}

model FilterGroup {
  id Int @id @default(autoincrement())

  name String
  slug String

  categoryId Int
  category   ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  options FilterOption[]

  sortOrder   Int     @default(100)
  isPublished Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, slug])
  @@index([categoryId, isPublished, sortOrder])
}

model FilterOption {
  id Int @id @default(autoincrement())

  name  String
  value String

  groupId Int
  group   FilterGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  products ProductFilterOption[]

  sortOrder   Int     @default(100)
  isPublished Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([groupId, value])
  @@index([groupId, isPublished, sortOrder])
}

model Product {
  id Int @id @default(autoincrement())

  slug  String @unique
  title String

  shortDescription String @default("")
  description      String @default("")

  badge String @default("")
  sku   String @default("")

  seoTitle       String @default("")
  seoDescription String @default("")

  categoryId Int
  category   ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  brandId Int?
  brand   Brand? @relation(fields: [brandId], references: [id], onDelete: SetNull)

  variants      ProductVariant[]
  images        ProductImage[]
  filterOptions ProductFilterOption[]
  orderItems    OrderItem[]

  isPublished Boolean @default(false)
  sortOrder   Int     @default(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, isPublished, sortOrder])
  @@index([brandId])
  @@index([createdAt])
}

model ProductVariant {
  id Int @id @default(autoincrement())

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name String @default("Стандарт")
  sku  String @default("")

  price    Int
  oldPrice Int?

  isActive Boolean @default(true)
  sortOrder Int    @default(100)

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, isActive, sortOrder])
}

model ProductImage {
  id Int @id @default(autoincrement())

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  imagePath String
  alt       String @default("")
  isMain    Boolean @default(false)
  sortOrder Int     @default(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, isMain, sortOrder])
}

model ProductFilterOption {
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  filterOptionId Int
  filterOption   FilterOption @relation(fields: [filterOptionId], references: [id], onDelete: Cascade)

  @@id([productId, filterOptionId])
  @@index([filterOptionId])
}

model Order {
  id Int @id @default(autoincrement())

  publicNumber String @unique
  idempotencyKey String @unique

  status OrderStatus @default(NEW)

  customerName String
  phone        String
  comment      String @default("")

  fulfillmentMethod FulfillmentMethod @default(PICKUP)
  deliveryAddress   String            @default("")

  total Int @default(0)

  source String @default("catalog")

  consentAccepted   Boolean  @default(false)
  consentAcceptedAt DateTime?

  internalComment String @default("")

  ipAddress String @default("")
  userAgent String @default("")

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([phone])
  @@index([createdAt])
}

model OrderItem {
  id Int @id @default(autoincrement())

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId Int?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  variantId Int?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  productTitleSnapshot String
  productSlugSnapshot  String
  variantNameSnapshot  String
  skuSnapshot          String @default("")
  imagePathSnapshot    String @default("")

  unitPrice Int
  quantity  Int
  lineTotal Int

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}
